<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.courseassignment.mapper.NotificationMapper">

    <resultMap id="NotificationMap" type="com.courseassignment.entity.Notification">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="type" column="type"/>
        <result property="isRead" column="is_read"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="NotificationMap">
        SELECT * FROM notification WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="NotificationMap">
        SELECT * FROM notification WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="findUnreadByUserId" resultMap="NotificationMap">
        SELECT * FROM notification WHERE user_id = #{userId} AND is_read = 0 ORDER BY created_at DESC
    </select>

    <select id="countUnreadByUserId" resultType="long">
        SELECT COUNT(*) FROM notification WHERE user_id = #{userId} AND is_read = 0
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification (user_id, title, content, type, is_read)
        VALUES (#{userId}, #{title}, #{content}, #{type}, #{isRead})
    </insert>

    <update id="markAsRead">
        UPDATE notification SET is_read = 1 WHERE id = #{id}
    </update>

    <update id="markAllAsRead">
        UPDATE notification SET is_read = 1 WHERE user_id = #{userId}
    </update>

    <delete id="deleteById">
        DELETE FROM notification WHERE id = #{id}
    </delete>

</mapper>
