<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.courseassignment.mapper.UserMapper">

    <resultMap id="UserMap" type="com.courseassignment.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="role" column="role"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="studentNo" column="student_no"/>
        <result property="teacherNo" column="teacher_no"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="UserMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="UserMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <select id="findByStudentNo" resultMap="UserMap">
        SELECT * FROM user WHERE student_no = #{studentNo}
    </select>

    <select id="findByTeacherNo" resultMap="UserMap">
        SELECT * FROM user WHERE teacher_no = #{teacherNo}
    </select>

    <!-- 动态多条件查询 -->
    <select id="findAll" resultMap="UserMap">
        SELECT * FROM user WHERE 1=1
        <if test="role != null and role != ''"> AND role = #{role} </if>
        <if test="keyword != null and keyword != ''">
            AND (real_name LIKE CONCAT('%', #{keyword}, '%') OR username LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY created_at DESC
    </select>

    <select id="findTeachers" resultMap="UserMap">
        SELECT * FROM user WHERE role = 'TEACHER' AND status = 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, real_name, role, student_no, teacher_no, phone, email, avatar)
        VALUES (#{username}, #{password}, #{realName}, #{role}, #{studentNo}, #{teacherNo}, #{phone}, #{email}, #{avatar})
    </insert>

    <update id="update">
        UPDATE user SET
        <if test="realName != null"> real_name = #{realName}, </if>
        <if test="phone != null"> phone = #{phone}, </if>
        <if test="email != null"> email = #{email}, </if>
        <if test="avatar != null"> avatar = #{avatar}, </if>
        <if test="status != null"> status = #{status}, </if>
        updated_at = NOW() WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM user WHERE id = #{id}
    </delete>

    <select id="countByRole" resultType="long">
        SELECT COUNT(*) FROM user WHERE role = #{role}
    </select>

</mapper>
